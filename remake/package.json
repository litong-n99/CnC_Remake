{
  "name": "cnc-remake",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "cd .. && husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.60.0",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.0",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@babylonjs/core": "^9.0.0",
    "@babylonjs/gui": "^9.6.2",
    "fengari": "^0.1.5",
    "fengari-web": "^0.1.4",
    "js-yaml": "^4.1.1"
  }
}
